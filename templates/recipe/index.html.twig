{% extends 'base.html.twig' %}

{% block title %}Recipe index{% endblock %}

{% block body %}
    <h1>Recipe index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Time</th>
                <th>Nb_people</th>
                <th>Difficulty</th>
                <th>Description</th>
                <th>Price</th>
                <th>Create_at</th>
                <th>Update_at</th>
                <th>Is_favorite</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for recipe in recipes %}
            <tr>
                <td>{{ recipe.id }}</td>
                <td>{{ recipe.name }}</td>
                <td>{{ recipe.time }}</td>
                <td>{{ recipe.nbPeople }}</td>
                <td>{{ recipe.difficulty }}</td>
                <td>{{ recipe.description }}</td>
                <td>{{ recipe.price }}</td>
                <td>{{ recipe.createAt ? recipe.createAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ recipe.updateAt ? recipe.updateAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ recipe.isFavorite ? 'Yes' : 'No' }}</td>
                <td>
                    <a href="{{ path('app_recipe_show', {'id': recipe.id}) }}">show</a>
                    <a href="{{ path('app_recipe_edit', {'id': recipe.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_recipe_new') }}">Create new</a>
{% endblock %}
