{% extends 'base.html.twig' %}

{% block title %}Ingredient index
{% endblock %}

{% block body %}
	<h1>Ingredient index</h1>
	<div class="text-dark count">
		{{ ingredients.getTotalItemCount() }} ingredient(s) found
	</div>


	<table class="table">
		<thead>
			<tr class="table-dark">
				<th>Id</th>
				<th>Nom</th>
				<th>PrixAuKilo</th>
				<th>DateCreation</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for ingredient in ingredients %}
				<tr class="table-success">
					<td>{{ ingredient.id }}</td>
					<td>{{ ingredient.nom }}</td>
					<td>{{ ingredient.prixAuKilo }}</td>
					<td>{{ ingredient.dateCreation ? ingredient.dateCreation|date('Y-m-d H:i:s') : '' }}</td>
					<td>
						<a class="text-dark" href="{{ path('app_ingredient_show', {'id': ingredient.id}) }}">show</a>
						<a class="text-dark" href="{{ path('app_ingredient_edit', {'id': ingredient.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
	<div class= "text-dark navigation d-flex justify-content-center" >
		{{ knp_pagination_render(ingredients) }}		
	</div>

	<a class="text-dark" href="{{ path('app_ingredient_new') }}">Create new</a>
{% endblock %}
